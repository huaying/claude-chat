# Slack Bot Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App-Level Token for Socket Mode (starts with xapp-)
SLACK_APP_TOKEN=xapp-your-app-token

# Slack Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret

# Default working directory for Claude Code sessions
DEFAULT_WORKING_DIR=/tmp/claude-workspace

# Session timeout in milliseconds (default: 30 minutes)
SESSION_TIMEOUT_MS=1800000

# Stream debounce delay in milliseconds (default: 1.5 seconds)
STREAM_DEBOUNCE_MS=1500

# Max Slack message length before truncation
MAX_SLACK_MESSAGE_LENGTH=3000

# Anthropic API Key — optional if already set in environment
# or if using existing `claude` CLI login credentials
# ANTHROPIC_API_KEY=sk-ant-your-api-key
